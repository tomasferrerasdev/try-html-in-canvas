{
  "manifest_version": 3,
  "name": "HTML-in-Canvas Shader",
  "version": "0.3.0",
  "description": "Snapshot the page with the experimental drawElement() API and apply fragment shaders or a built-in 3D roll preset on top.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "HTML Shader",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["activeTab", "scripting"]
}
